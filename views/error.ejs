<% layout("/layouts/boilerplate") %>

<div class="container d-flex justify-content-center align-items-center"
     style="min-height: 80vh;">

    <div class="card shadow-lg border-0 text-center p-5"
         style="max-width: 600px; width: 100%; border-radius: 20px;">

        <div class="mb-4">

            <h1 class="display-1 text-danger fw-bold">

                <%= err.statusCode %>

            </h1>

        </div>

        <h2 class="fw-bold mb-3">

            Oops!

        </h2>

        <p class="text-muted fs-5 mb-4">

            <%= err.message %>

        </p>

        <a href="/listings"
           class="btn btn-dark btn-lg rounded-pill px-4">

            Back To Home

        </a>

    </div>

</div>