<% layout("/layouts/boilerplate") %>
<link rel="stylesheet" href="/stylesheets/signup.css">

<div class="signup-container">

    <div class="signup-card">

        <h1 class="signup-title">
            Create Account
        </h1>

        <p class="signup-subtitle">
            Join Wanderlust and start exploring amazing places.
        </p>

        <form
            action="/signup"
            method="POST"
            class="signup-form"
            novalidate class="needs-validation"
        >

            <div class="form-group">

                <label for="username">
                    Username
                </label>

                <input
                    type="text"
                    id="username"
                    name="username"
                    placeholder="Enter username"
                    required
                    class="form-control"
                >

            </div>

            <div class="form-group">

                <label for="email">
                    Email
                </label>

                <input
                    type="email"
                    id="email"
                    name="email"
                    placeholder="Enter email"
                    required
                    class="form-control"
                >

            </div>

            <div class="form-group">

                <label for="password">
                    Password
                </label>

                <input
                    type="password"
                    id="password"
                    name="password"
                    placeholder="Enter password"
                    required
                    class="form-control"
                >

            </div>

            <button
                type="submit"
                class="signup-btn"
            >
                Sign Up
            </button>

        </form>

        <div class="login-link">

            Already have an account?

            <a href="/login">
                Log In
            </a>

        </div>

    </div>

</div>